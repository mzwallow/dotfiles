# EditorConfig is awesome: https://EditorConfig.org
root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{lua,nix}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
indent_size = 2

[*.{json,jsonc}]
indent_style = tab
indent_size = 2

[*.go]
indent_style = tab
indent_size = 4
